# BillPay Backend Configuration
# Copy this file to .env and fill in your actual values

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Database
MONGO_URI=mongodb://localhost:27017/malabarbazaar
MONGO_TEST_URI=mongodb://localhost:27017/malabarbazaar-test

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=development

# Email Notifications (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@malabarbazaar.com

# SMS Notifications (Twilio or AWS SNS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Or use AWS SNS instead
AWS_SNS_REGION=ap-south-1
AWS_SNS_ACCESS_KEY=your_aws_access_key
AWS_SNS_SECRET_KEY=your_aws_secret_key

# Admin Settings
ADMIN_EMAIL=admin@malabarbazaar.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=10

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_key_here

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Feature Flags
ENABLE_AUTOPAY=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_ADMIN_DASHBOARD=true

# Commission Rate (for admin earnings)
BILLPAY_COMMISSION_RATE=0.0045

# Payment Limits
MIN_PAYMENT_AMOUNT=1
MAX_PAYMENT_AMOUNT=100000
HIGH_VALUE_THRESHOLD=5000

# Dispute Settings
DISPUTE_SLA_HOURS=48
MAX_DISPUTES_PER_DAY=5

# Mandate Settings
MANDATE_MAX_RETRIES=3
MANDATE_RETRY_INTERVAL_HOURS=24

# Webhook (for Razorpay notifications)
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_URL=https://yourapp.com/webhooks/razorpay

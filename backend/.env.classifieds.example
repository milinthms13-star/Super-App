# Classifieds Backend Environment Configuration
# Copy to .env and fill in your values

# Google Maps Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Image Upload Configuration
MAX_IMAGE_SIZE=5242880
MAX_IMAGES_PER_LISTING=10
IMAGE_UPLOAD_DIR=./uploads/classifieds

# Database Indexing
ENABLE_DB_INDEXES=true

# Rate Limiting
LISTINGS_PER_HOUR=5
MESSAGES_PER_HOUR=30
REPORTS_PER_HOUR=10
SEARCHES_PER_MINUTE=50

# Spam Detection
SPAM_SCORE_THRESHOLD=70
ENABLE_CONTENT_FILTERING=true

# WebSocket Configuration
WS_NAMESPACE=/classifieds
WS_UPDATE_INTERVAL=5000

# Monetization
FEATURED_LISTING_PRICE=299
URGENT_LISTING_PRICE=499
SELLER_PRO_PRICE=999

# Audit Logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_DIR=./logs/classifieds

# Geolocation
DEFAULT_LOCATION_RADIUS=50
ENABLE_LOCATION_SEARCH=true

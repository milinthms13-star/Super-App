# Environment
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
AUTH_STORAGE=memory

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://localhost:3002

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/malabarbazaar
# For production with replica set:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/malabarbazaar?retryWrites=true&w=majority

# Redis Configuration (optional, for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Email Configuration
# Choose one: gmail-api, ses, or smtp

# Option 0: Gmail API (Recommended for development - 10K/day free)
# 1. Download credentials.json from Google Cloud Console
# 2. Place it in the backend folder
# 3. Set EMAIL_SERVICE=gmail-api
# 4. On first run, visit: http://localhost:5000/api/auth/authorize-gmail
# 5. Grant permissions and get your token
# EMAIL_SERVICE=gmail-api
# GMAIL_USER=your-email@gmail.com
# GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=your-client-secret

# Option 1: Gmail SMTP
EMAIL_SERVICE=Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=anjaaniaditi@gmail.com
EMAIL_PASS=Thathu@110
EMAIL_FROM=anjaaniaditi@gmail.com

# Option 2: AWS SES (recommended for production)
# EMAIL_SERVICE=ses
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# EMAIL_FROM=noreply@yourdomain.com

# Option 3: SendGrid
# EMAIL_SERVICE=sendgrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key

# Option 4: Custom SMTP
# EMAIL_HOST=your-smtp-server.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-smtp-username
# EMAIL_PASS=your-smtp-password
# EMAIL_FROM=noreply@yourdomain.com

# Security
JWT_SECRET=your-super-secure-jwt-secret-here-change-this-in-production
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# File Upload (if needed)
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-here
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# CDN (optional)
CDN_URL=https://cdn.yourdomain.com

# Database Connection Pool
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=5

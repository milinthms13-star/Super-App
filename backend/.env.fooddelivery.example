# Food Delivery Phase 1 - Environment Configuration

# Copy this file to .env and fill in the values

# ==================== APPLICATION ====================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ==================== DATABASE ====================
MONGODB_URI=mongodb://localhost:27017/fooddelivery
# OR for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fooddelivery?retryWrites=true&w=majority

# ==================== JWT ====================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_min_32_chars_long
JWT_EXPIRE=30d

# ==================== TWILIO (SMS) ====================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Or use Sendgrid:
# SENDGRID_API_KEY=your_sendgrid_api_key

# ==================== AWS S3 (FILE UPLOADS) ====================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=fooddelivery-bucket

# ==================== SOCIAL LOGIN ====================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Apple Sign In
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_BUNDLE_ID=com.fooddelivery.app

# ==================== REDIS (CACHING & SESSIONS) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=optional_redis_password

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# ==================== SECURITY ====================
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Account lockout after failed attempts
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=30

# OTP Configuration
OTP_LENGTH=6
OTP_VALIDITY_MINUTES=10
MAX_OTP_ATTEMPTS=3

# ==================== ANALYTICS ====================
MIXPANEL_TOKEN=your_mixpanel_token
SEGMENT_WRITE_KEY=your_segment_write_key

# ==================== THIRD-PARTY SERVICES ====================
# Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Payment Gateway (Phase 4)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ==================== WORKER/QUEUE ====================
BULL_MQ_REDIS_HOST=localhost
BULL_MQ_REDIS_PORT=6379

# ==================== FEATURE FLAGS ====================
ENABLE_SOCIAL_LOGIN=true
ENABLE_OTP_LOGIN=true
ENABLE_EMAIL_PASSWORD_LOGIN=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PROFILE_PICTURE_UPLOAD=true

# ==================== API DOCUMENTATION ====================
ENABLE_SWAGGER_DOCS=true
SWAGGER_DOC_PATH=/api/fooddelivery/docs

# Firebase Configuration - Environment Variables
# Copy this file to .env and fill in your Firebase credentials

# Firebase Web App Configuration
# Get these values from your Firebase Project Settings
# https://console.firebase.google.com/ → Project Settings

REACT_APP_FIREBASE_API_KEY=YOUR_API_KEY_HERE
REACT_APP_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
REACT_APP_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
REACT_APP_FIREBASE_APP_ID=YOUR_APP_ID

# Optional: For production environment
# REACT_APP_ENVIRONMENT=production

# WebRTC / VoIP (LinkUp Calls)
# Comma-separated STUN URLs (optional; defaults are used if empty)
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN relay (recommended for production mobile networks)
# Example:
# WEBRTC_TURN_URLS=turn:turn.yourdomain.com:3478,turns:turn.yourdomain.com:5349
# WEBRTC_TURN_USERNAME=your_turn_username
# WEBRTC_TURN_CREDENTIAL=your_turn_password
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# Classifieds Module Environment Configuration
# Copy to .env.local and fill in your values

# Google Maps API Configuration
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# Classifieds WebSocket Configuration
REACT_APP_WS_URL=ws://localhost:5000

# Image Upload Configuration
REACT_APP_MAX_IMAGE_SIZE=5242880
REACT_APP_MAX_IMAGES_PER_LISTING=10

# Monetization Settings
REACT_APP_FEATURED_LISTING_PRICE=299
REACT_APP_URGENT_LISTING_PRICE=499
REACT_APP_SELLER_PRO_PRICE=999

# Feature Flags
REACT_APP_ENABLE_VOICE_SEARCH=true
REACT_APP_ENABLE_BULK_IMPORT=true
REACT_APP_ENABLE_AUTO_RELIST=true
